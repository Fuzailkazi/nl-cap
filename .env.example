# =============================================================================
# Mutual Fund Advisor Intelligence Suite — environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and never committed. This template only documents the VARIABLE
# NAMES — keep all real secrets in `.env.local`.
#
#   cp .env.example .env.local
#
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Postgres + pgvector) — the single RAG corpus + action queue
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
# Public project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon / public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY. Never import into client components.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (Settings → Database) — used by migrations
# and ingest/eval scripts run via tsx. e.g.
# postgresql://postgres:[PASSWORD]@db.abcdefgh.supabase.co:5432/postgres
SUPABASE_DB_URL=

# -----------------------------------------------------------------------------
# OpenAI — both LLM GENERATION and EMBEDDINGS (see docs/DEVIATIONS.md #4).
# Generation: FAQ answers, weekly pulse, fee explainer, voice greeting — calls
# live in lib/llm/ with named prompt exports. Embeddings: lib/rag/ corpus +
# query vectors. A single OPENAI_API_KEY powers both.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Generation model. Override only if intentionally changing it.
OPENAI_GEN_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small
# Must match the vector(N) dimension in the corpus migration. 3-small = 1536.
EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# Anthropic — DEPRECATED. Generation moved to OpenAI (DEVIATIONS.md #4). Kept
# only so the swap can be reverted by restoring requireGeneration() to use it.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
